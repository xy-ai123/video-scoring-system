# --- Database ---
# Postgres connection string. Railway: copy from Postgres plugin -> Connect.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_scoring

# --- Redis ---
# Redis connection string for BullMQ. Railway: copy from Redis plugin -> Connect.
REDIS_URL=redis://localhost:6379

# --- Webhook (Apps Script -> /api/webhooks/google-form) ---
# Random long secret. Same value MUST be set in Apps Script Script Properties.
WEBHOOK_SECRET=replace-me-with-a-long-random-string

# --- Google Drive Service Account ---
# Base64-encode the JSON key file: `base64 -i service-account.json | tr -d '\n'`
GOOGLE_SERVICE_ACCOUNT_JSON=replace-me-base64-encoded-service-account-json

# --- Algorithm Engine ---
# Where the worker POSTs videos for scoring (multipart/form-data).
ALGO_ENGINE_URL=https://your-algorithm-engine.example.com/score
ALGO_ENGINE_API_KEY=replace-me
# Multipart form field name for the file part. Default: video
ALGO_ENGINE_FIELD_NAME=video

# --- Resend (email) ---
RESEND_API_KEY=re_replace_me
# Must use a Resend-verified sender domain.
RESEND_FROM=Video Scoring <noreply@yourdomain.com>

# --- NextAuth ---
# Public URL of the deployed web app (used for OAuth callbacks too).
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# --- Google OAuth (admin sign-in) ---
GOOGLE_OAUTH_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace-me

# --- Admin allowlist ---
# Comma-separated emails. Only these users can sign in to /admin.
ADMIN_EMAILS=demo-admin@example.com

# --- Clipping pipeline (Dashboard 1) ---
# Absolute path to the robot-video-pipeline checkout that owns the Python
# clipping scripts (pull_from_drive.py, detect_hands.py,
# upload_clips_to_drive.py). Default: ~/robot-video-pipeline.
ROBOT_PIPELINE_PATH=/Users/xinyi/robot-video-pipeline

# --- Dashboard 2 (apps/web-algo) ---
# Drive folder ID that holds CLIPPED + LABELLED videos waiting to be sent
# to the algorithm engine. Must be shared with the service account.
HANDOFF_DRIVE_FOLDER_ID=1Jdse6zWG9RKYlJaxYonVqM5gsSv2cx4M

# --- Misc ---
LOG_LEVEL=info
NODE_ENV=production

# Public URL for the web app (used by worker emails to link back to /admin).
WEB_PUBLIC_URL=https://your-deployment.example.com

# --- Mock mode (local development) ---
# When all *_MOCK flags below are true, you can run the system end-to-end
# without any external service. Real values for ALGO_ENGINE_URL/API_KEY,
# RESEND_*, GOOGLE_OAUTH_*, GOOGLE_SERVICE_ACCOUNT_JSON can be left as the
# placeholder strings above.

# Bypass Google OAuth: a mock admin can sign in by entering any email in ADMIN_EMAILS.
AUTH_MOCK=true
# Web UI hint so the login page renders the mock form. Mirror of AUTH_MOCK.
NEXT_PUBLIC_AUTH_MOCK=true
# Skip real Drive download; worker fabricates a 1KB stream.
DRIVE_MOCK=true
# Skip real Algorithm Engine; worker returns deterministic mock scores.
ALGO_ENGINE_MOCK=true
# Skip real Resend send; worker logs email instead.
RESEND_MOCK=true
